# Database (Port 5433 used to avoid conflict with local postgres)
DATABASE_URL="postgresql://mcpuser:mcppassword@localhost:5433/mcpflow?schema=public"

# Database Container Configuration
POSTGRES_USER=mcpuser
POSTGRES_PASSWORD=mcppassword
POSTGRES_DB=mcpflow
POSTGRES_PORT=5433

# Application
PORT=3001
NODE_ENV=development
